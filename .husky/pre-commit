echo "\n🏗️  👷  Running pre-commit checks before your filth reaches the repo  👷  🏗️\n"

echo "📐 Checking backend formatting...\n"
cd backend && bunx prettier --check . || {
  echo "\n🤢🤮🤢🤮  YOUR FORMATTING IS ABSOLUTELY DISGUSTING  🤢🤮🤢🤮"
  echo "Run \`cd backend && bunx prettier --write .\` to fix, stage the changes, and try again.\n"
  exit 1
}
cd ..

echo "🔎 Checking backend types...\n"
cd backend && bunx tsc --noEmit || {
  echo "\n💀☠️💀☠️  TYPE ERRORS DETECTED. THE COMPILER IS DISGUSTED WITH YOU  ☠️💀☠️💀"
  echo "Fix the TypeScript errors above, stage the changes, and try again.\n"
  exit 1
}
cd ..

echo "🧪 Running backend tests...\n"
cd backend && bun test || {
  echo "\n🔥🚨🔥🚨  TESTS ARE FAILING. DO NOT SHIP THIS GARBAGE  🚨🔥🚨🔥"
  echo "Fix the failing tests above, stage the changes, and try again.\n"
  exit 1
}
cd ..

echo "📐 Checking frontend formatting...\n"
cd frontend && bunx prettier --check . || {
  echo "\n🤢🤮🤢🤮  YOUR FRONTEND FORMATTING IS ABSOLUTELY DISGUSTING  🤢🤮🤢🤮"
  echo "Run \`cd frontend && bunx prettier --write .\` to fix, stage the changes, and try again.\n"
  exit 1
}
cd ..

echo "🔎 Checking frontend types...\n"
cd frontend && bunx tsc --noEmit || {
  echo "\n💀☠️💀☠️  FRONTEND TYPE ERRORS DETECTED. THE COMPILER IS DISGUSTED WITH YOU  ☠️💀☠️💀"
  echo "Fix the TypeScript errors above, stage the changes, and try again.\n"
  exit 1
}
cd ..

echo "🧪 Running frontend tests...\n"
cd frontend && bun run test || {
  echo "\n🔥🚨🔥🚨  FRONTEND TESTS FAILING. DO NOT SHIP THIS GARBAGE  🚨🔥🚨🔥"
  echo "Fix the failing tests above, stage the changes, and try again.\n"
  exit 1
}
cd ..

echo "\n✅ 🎉 All checks passed. Committing your (barely acceptable) code. 🎉 ✅\n"
