DATABASE_URL=postgresql://postgres:postgres@localhost:5432/booksclub
REDIS_URL=redis://localhost:6379
PORT=8080
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
EMBEDDING_CHUNK_SIZE=20

# Auth.js
# Signing/encryption secret for JWT session tokens. Required. Generate with: openssl rand -base64 33
AUTH_SECRET=
# Backend's own base URL, used by @auth/express to build callback URLs
AUTH_URL=http://localhost:8080
# JWT session max age in seconds (2592000 = 30 days)
SESSION_MAX_AGE=2592000
# Cookie domain. Leave blank for localhost dev; set to the deployed domain in production, e.g. .example.com
COOKIE_DOMAIN=
