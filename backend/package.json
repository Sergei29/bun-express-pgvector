{
  "name": "backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun src/db/seed.ts",
    "db:embed": "bun src/db/embedding.ts",
    "db:studio": "drizzle-kit studio",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "check-all": "bun run format:check && bun run type-check && bun test"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@auth/drizzle-adapter": "^1.11.2",
    "@auth/express": "^0.12.2",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.44.2",
    "express": "^4.21.2",
    "ioredis": "^5.11.1",
    "papaparse": "^5.4.1",
    "pg": "^8.13.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.1",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "typescript": "^5.7.3"
  }
